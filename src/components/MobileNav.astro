---
import { SITE } from '~/config/site';

const navLinks = [
  { href: '/services/', label: 'Services' },
  { href: '/industries/', label: 'Industries' },
  { href: '/locations/', label: 'Locations' },
  { href: '/blog/', label: 'Blog' },
  { href: '/about/', label: 'About' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);

const telHref = `tel:${SITE.phone.replace(/\s+/g, '')}`;
---

<button
  type="button"
  class="inline-flex h-11 w-11 items-center justify-center rounded-lg text-slate-700 transition-colors hover:bg-slate-100 hover:text-brand-700 md:hidden"
  aria-label="Open menu"
  aria-controls="mobile-nav"
  aria-expanded="false"
  data-mobile-nav-trigger
>
  <svg
    class="h-6 w-6"
    aria-hidden="true"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <line x1="3" y1="6" x2="21" y2="6"></line>
    <line x1="3" y1="12" x2="21" y2="12"></line>
    <line x1="3" y1="18" x2="21" y2="18"></line>
  </svg>
</button>

<div
  id="mobile-nav"
  class="fixed inset-0 z-50 pointer-events-none md:hidden"
  data-mobile-nav
  data-open="false"
  aria-hidden="true"
>
  <div
    class="absolute inset-0 bg-slate-900/60 opacity-0 transition-opacity duration-200 ease-out"
    data-mobile-nav-backdrop
  >
  </div>

  <aside
    class="absolute inset-y-0 right-0 flex w-[88vw] max-w-sm translate-x-full flex-col bg-white shadow-2xl transition-transform duration-200 ease-out"
    data-mobile-nav-drawer
    aria-label="Mobile navigation"
  >
    <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3">
      <a
        href="/"
        class="flex items-center gap-2 font-bold text-slate-900"
        data-mobile-nav-link
      >
        <span
          class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-brand-600 text-sm text-white"
          aria-hidden="true"
        >
          AI
        </span>
        <span class="text-base">{SITE.name}</span>
      </a>
      <button
        type="button"
        class="-mr-1 inline-flex h-10 w-10 items-center justify-center rounded-md text-slate-700 transition-colors hover:bg-slate-100"
        aria-label="Close menu"
        data-mobile-nav-close
      >
        <svg
          class="h-5 w-5"
          aria-hidden="true"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <div class="border-b border-slate-200 bg-white px-4 py-3">
      <a
        href="/contact/"
        class="flex min-h-[48px] items-center justify-center rounded-lg bg-brand-700 px-4 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-brand-800"
        data-mobile-nav-link
      >
        Book a free 30-min call
      </a>
    </div>

    <nav class="bg-white px-2 py-2" aria-label="Mobile primary">
      <ul>
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'flex min-h-[44px] items-center rounded-md px-3 py-2 text-base font-medium transition-colors',
                  isActive(link.href)
                    ? 'bg-brand-50 text-brand-700'
                    : 'text-slate-800 hover:bg-slate-100 hover:text-brand-700',
                ]}
                aria-current={isActive(link.href) ? 'page' : undefined}
                data-mobile-nav-link
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex-1 bg-white" aria-hidden="true"></div>

    <div class="border-t border-slate-200 bg-slate-50 px-4 py-3">
      <div class="grid grid-cols-2 gap-2">
        <a
          href={telHref}
          class="flex min-h-[40px] items-center justify-center gap-1.5 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 transition hover:border-brand-400"
          data-mobile-nav-link
        >
          <svg
            class="h-4 w-4"
            aria-hidden="true"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
          Call
        </a>
        <a
          href={`mailto:${SITE.email}`}
          class="flex min-h-[40px] items-center justify-center gap-1.5 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 transition hover:border-brand-400"
          data-mobile-nav-link
        >
          <svg
            class="h-4 w-4"
            aria-hidden="true"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
          Email
        </a>
      </div>
    </div>
  </aside>
</div>

<style>
  [data-mobile-nav][data-open='true'] {
    pointer-events: auto;
  }
  [data-mobile-nav][data-open='true'] [data-mobile-nav-backdrop] {
    opacity: 1;
  }
  [data-mobile-nav][data-open='true'] [data-mobile-nav-drawer] {
    translate: 0;
  }
  body.mobile-nav-open {
    overflow: hidden;
  }
</style>

<script>
  const nav = document.querySelector<HTMLElement>('[data-mobile-nav]');
  const trigger = document.querySelector<HTMLButtonElement>(
    '[data-mobile-nav-trigger]',
  );
  const closeBtn = document.querySelector<HTMLButtonElement>(
    '[data-mobile-nav-close]',
  );
  const backdrop = document.querySelector<HTMLElement>(
    '[data-mobile-nav-backdrop]',
  );
  const links = document.querySelectorAll<HTMLAnchorElement>(
    '[data-mobile-nav-link]',
  );

  if (nav && trigger) {
    const setOpen = (open: boolean) => {
      nav.dataset.open = open ? 'true' : 'false';
      nav.setAttribute('aria-hidden', open ? 'false' : 'true');
      trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
      trigger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      document.body.classList.toggle('mobile-nav-open', open);
    };

    trigger.addEventListener('click', () => setOpen(true));
    closeBtn?.addEventListener('click', () => setOpen(false));
    backdrop?.addEventListener('click', () => setOpen(false));
    links.forEach((link) =>
      link.addEventListener('click', () => setOpen(false)),
    );
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && nav.dataset.open === 'true') setOpen(false);
    });
  }
</script>
