---
interface Props {
  title?: string;
  body?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  title = 'Ready to put AI to work in your business?',
  body = 'Book a free 30-minute call. We will diagnose your highest-impact AI opportunity and outline what a project would look like.',
  primaryHref = '/contact/',
  primaryLabel = 'Book a free call',
  secondaryHref = '/services/',
  secondaryLabel = 'Explore services',
} = Astro.props;
---

<section class="mt-20 overflow-hidden rounded-3xl bg-brand-700 px-6 py-12 sm:px-12">
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="text-2xl font-bold text-white sm:text-3xl">{title}</h2>
    <p class="mt-3 text-brand-100">{body}</p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a
        href={primaryHref}
        class="rounded-lg bg-white px-5 py-3 text-sm font-semibold text-brand-700 shadow-sm transition hover:bg-brand-50"
      >
        {primaryLabel}
      </a>
      <a
        href={secondaryHref}
        class="rounded-lg border border-brand-300 px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-600"
      >
        {secondaryLabel}
      </a>
    </div>
  </div>
</section>
