---
interface LinkItem {
  href: string;
  label: string;
  description?: string;
}

interface Props {
  title: string;
  links: LinkItem[];
  intro?: string;
  ariaLabel?: string;
}

const { title, links, intro, ariaLabel } = Astro.props;
---

{
  links.length > 0 && (
    <section
      class="mt-16 rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:p-8"
      aria-label={ariaLabel ?? title}
    >
      <h2 class="text-xl font-bold text-slate-900 sm:text-2xl">{title}</h2>
      {intro && <p class="mt-2 text-slate-600">{intro}</p>}
      <ul class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class="group block rounded-xl border border-slate-200 bg-white p-4 transition hover:border-brand-400 hover:shadow-sm"
            >
              <p class="font-semibold text-slate-900 group-hover:text-brand-700">
                {link.label}
              </p>
              {link.description && (
                <p class="mt-1 text-sm text-slate-600">{link.description}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}
