---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import { SITE } from '~/config/site';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Contact', url: '/contact/' },
];
---

<BaseLayout
  title={`Contact ${SITE.name}`}
  description={`Get in touch with ${SITE.name}. Book a free 30-minute call to discuss your AI project.`}
  canonical="/contact/"
  breadcrumbs={breadcrumbs}
>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <Breadcrumbs items={breadcrumbs} />
    <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
      Contact us
    </h1>
    <p class="mt-4 text-lg text-slate-700">
      Book a free 30-minute call to talk through your AI project. No
      sales pitch, just a useful conversation about whether and how AI fits
      your business.
    </p>

    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-700">
          Email
        </p>
        <p class="mt-2 text-lg font-semibold text-slate-900">
          <a href={`mailto:${SITE.email}`} class="hover:text-brand-700">
            {SITE.email}
          </a>
        </p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-700">
          Phone
        </p>
        <p class="mt-2 text-lg font-semibold text-slate-900">
          <a href={`tel:${SITE.phone.replace(/\s+/g, '')}`} class="hover:text-brand-700">
            {SITE.phone}
          </a>
        </p>
      </div>
    </div>

    <p class="mt-10 text-sm text-slate-500">
      Prefer a form? Wire up a contact form when you are ready. Cloudflare
      Workers + Astro endpoints make this trivial to add later.
    </p>
  </article>
</BaseLayout>
