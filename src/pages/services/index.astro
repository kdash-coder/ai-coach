---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import CTA from '~/components/CTA.astro';
import { sectors } from '~/data/sectors';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Services', url: '/services/' },
];
---

<BaseLayout
  title="AI Consultancy Services"
  description="Practical AI consultancy services: strategy, automation, training and custom AI solutions for UK businesses."
  canonical="/services/"
  breadcrumbs={breadcrumbs}
>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <Breadcrumbs items={breadcrumbs} />
    <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
      AI Consultancy Services
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-slate-700">
      Four practical ways we help UK businesses adopt AI. Pick the one that
      matches where you are, most clients start with strategy or training, then
      move to automation and custom builds.
    </p>

    <ul class="mt-10 grid gap-6 md:grid-cols-2">
      {
        sectors.map((s) => (
          <li>
            <article class="flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-6">
              <h2 class="text-2xl font-bold text-slate-900">
                <a href={`/services/${s.slug}/`} class="hover:text-brand-700">
                  {s.name}
                </a>
              </h2>
              <p class="mt-2 text-slate-600">{s.tagline}</p>
              <p class="mt-4 text-slate-700">{s.description}</p>
              <p class="mt-6">
                <a
                  href={`/services/${s.slug}/`}
                  class="text-sm font-semibold text-brand-700 hover:text-brand-900"
                >
                  Learn more about {s.shortName} &rarr;
                </a>
              </p>
            </article>
          </li>
        ))
      }
    </ul>

    <CTA />
  </section>
</BaseLayout>
